{"config":{"lang":["en"],"separator":"[\\s\\-]+","pipeline":["stopWordFilter"],"fields":{"title":{"boost":1000.0},"text":{"boost":1.0},"tags":{"boost":1000000.0}}},"docs":[{"location":"index.html","title":"Car.102 \u2014 \u667a\u80fd\u5faa\u8ff9\u5c0f\u8f66","text":"<p>MCU: TI MSPM0G3507 | IDE: CCS Theia | SDK: MSPM0 SDK 2.09</p> <p>Car.102 \u662f\u57fa\u4e8e TI MSPM0G3507 \u5fae\u63a7\u5236\u5668\u7684\u667a\u80fd\u5faa\u8ff9\u5c0f\u8f66\uff0c\u91c7\u7528 8 \u8def\u7070\u5ea6\u4f20\u611f\u5668\u68c0\u6d4b\u8d5b\u9053\u9ed1\u7ebf\uff0c\u901a\u8fc7 \u53cc\u8def PID \u63a7\u5236\u7b97\u6cd5\u5b9e\u73b0\u9ad8\u901f\u7a33\u5b9a\u5faa\u8ff9\u3002\u652f\u6301 OLED \u663e\u793a\u3001UART \u8c03\u8bd5\u8f93\u51fa\u3001\u60ef\u6027\u5bfc\u822a\u7b49\u591a\u79cd\u529f\u80fd\u3002</p>"},{"location":"index.html#_1","title":"\u7cfb\u7edf\u67b6\u6784","text":"<pre><code>\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n\u2502                      Car.102 \u7cfb\u7edf                        \u2502\n\u251c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2524\n\u2502  \u611f\u77e5\u5c42 \u2502 \u7070\u5ea6\u4f20\u611f\u5668 | IMU (BNO08X/660RB/MPU6050)  \u2502\n\u2502         \u2502 \u8d85\u58f0\u6ce2 | VL53L0X \u6fc0\u5149\u6d4b\u8ddd                    \u2502\n\u251c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2524\n\u2502  \u51b3\u7b56\u5c42 \u2502 PID \u63a7\u5236 (\u8f6c\u5411 + \u901f\u5ea6) \u2502 \u59ff\u6001\u878d\u5408           \u2502\n\u251c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2524\n\u2502  \u6267\u884c\u5c42 \u2502 \u76f4\u6d41\u7535\u673a (\u53cc\u8def) \u2502 OLED \u663e\u793a \u2502 UART \u8f93\u51fa    \u2502\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n</code></pre>"},{"location":"index.html#_2","title":"\u6838\u5fc3\u529f\u80fd","text":"\u529f\u80fd \u8bf4\u660e \u5faa\u8ff9\u63a7\u5236 8 \u8def\u7070\u5ea6\u4f20\u611f\u5668\u68c0\u6d4b\u8d5b\u9053\u9ed1\u7ebf\uff0cPID \u8ba1\u7b97\u8f6c\u5411\u91cf \u53cc\u73af PID \u8f6c\u5411 PID + \u5de6/\u53f3\u901f\u5ea6 PID\uff0c\u5b9e\u73b0\u5e73\u6ed1\u5faa\u8ff9 \u4e22\u7ebf\u5904\u7406 \u8fde\u7eed\u4e22\u7ebf\u4fdd\u6301\u4e0a\u6b21\u504f\u5dee\uff0c\u8d85\u8fc7\u9608\u503c\u81ea\u52a8\u505c\u8f66 \u72b6\u6001\u663e\u793a OLED \u5b9e\u65f6\u663e\u793a\u504f\u5dee\u3001\u7535\u673a\u8f93\u51fa\u3001PID \u53c2\u6570\u3001\u7070\u5ea6\u503c \u8c03\u8bd5\u8f93\u51fa UART \u6bcf\u79d2 50 \u5e27\u8f93\u51fa\u8fd0\u884c\u6570\u636e"},{"location":"index.html#_3","title":"\u786c\u4ef6\u5e73\u53f0","text":"\u7ec4\u4ef6 \u578b\u53f7 \u63cf\u8ff0 \u4e3b\u63a7 MSPM0G3507 Arm Cortex-M0+, 80MHz \u7070\u5ea6\u4f20\u611f\u5668 8 \u8def\u6570\u5b57 8 \u901a\u9053\u7ea2\u5916\u53cd\u5c04\u4f20\u611f\u5668 IMU BNO08X / IMU660RB / MPU6050 9 \u8f74\u59ff\u6001\u68c0\u6d4b OLED 0.96\" 128\u00d764 \u8f6f\u4ef6 I2C \u9a71\u52a8 \u7535\u673a \u76f4\u6d41\u51cf\u901f\u7535\u673a \u53cc\u8def\u72ec\u7acb\u9a71\u52a8 \u7f16\u7801\u5668 \u970d\u5c14\u7f16\u7801\u5668 \u95ed\u73af\u901f\u5ea6\u53cd\u9988 \u6d4b\u8ddd VL53L0X / \u8d85\u58f0\u6ce2 \u907f\u969c\u4e0e\u6d4b\u8ddd"},{"location":"index.html#_4","title":"\u5feb\u901f\u5f00\u59cb","text":""},{"location":"index.html#_5","title":"\u7f16\u8bd1","text":"<pre><code># \u4f7f\u7528 CCS Theia \u6253\u5f00\u9879\u76ee\n# \u5bfc\u5165: File \u2192 Open Project \u2192 car.102\n# \u7f16\u8bd1: Ctrl+B\n# \u70e7\u5f55: F11\n</code></pre>"},{"location":"index.html#_6","title":"\u4e32\u53e3\u8c03\u8bd5","text":"<pre><code># \u6ce2\u7279\u7387: 115200\n# \u6570\u636e\u683c\u5f0f: dev:\u00b1NNN L:NNN R:NNN cnt:N SL:NNN SR:NNN\n</code></pre>"},{"location":"architecture.html","title":"\u8f6f\u4ef6\u67b6\u6784","text":""},{"location":"architecture.html#_2","title":"\u6a21\u5757\u7ed3\u6784","text":"<pre><code>car.102/\n\u251c\u2500\u2500 main.c                    # \u4e3b\u5faa\u73af\uff1a\u4f20\u611f\u5668\u8bfb\u53d6 \u2192 PID \u8ba1\u7b97 \u2192 \u7535\u673a\u63a7\u5236\n\u251c\u2500\u2500 main.h                    # \u5934\u6587\u4ef6\u5305\u542b\n\u251c\u2500\u2500 Drivers/\n\u2502   \u251c\u2500\u2500 BNO08X_UART_RVC/      # BNO08X \u59ff\u6001\u4f20\u611f\u5668\n\u2502   \u251c\u2500\u2500 Control/               # \u63a7\u5236\u903b\u8f91 (\u6309\u952e\u3001\u8702\u9e23\u5668)\n\u2502   \u251c\u2500\u2500 Encoder/               # \u970d\u5c14\u7f16\u7801\u5668\u8bfb\u53d6\n\u2502   \u251c\u2500\u2500 Grayscale/             # 8 \u8def\u7070\u5ea6\u4f20\u611f\u5668\n\u2502   \u251c\u2500\u2500 IMU660RB/              # \u59ff\u6001\u878d\u5408\u7b97\u6cd5\n\u2502   \u251c\u2500\u2500 LSM6DSV16X/            # 6 \u8f74 IMU \u9a71\u52a8\n\u2502   \u251c\u2500\u2500 MPU6050/               # MPU6050 + DMP \u9a71\u52a8\n\u2502   \u251c\u2500\u2500 MSPM0/                 # \u65f6\u949f\u548c\u4e2d\u65ad\u914d\u7f6e\n\u2502   \u251c\u2500\u2500 Motor/                 # \u76f4\u6d41\u7535\u673a PWM \u9a71\u52a8\n\u2502   \u251c\u2500\u2500 OLED_* /               # OLED \u663e\u793a (I2C/SPI \u591a\u7248\u672c)\n\u2502   \u251c\u2500\u2500 PID/                   # PID \u63a7\u5236\u5668\n\u2502   \u251c\u2500\u2500 Ultrasonic_*/          # \u8d85\u58f0\u6ce2\u6d4b\u8ddd\n\u2502   \u251c\u2500\u2500 VL53L0X/               # \u6fc0\u5149\u6d4b\u8ddd\n\u2502   \u2514\u2500\u2500 WIT/                   # WIT \u4e32\u53e3\u901a\u4fe1\n\u2514\u2500\u2500 mspm0-modules.syscfg      # SysConfig \u786c\u4ef6\u914d\u7f6e\n</code></pre>"},{"location":"architecture.html#_3","title":"\u4e3b\u5faa\u73af\u6d41\u7a0b","text":"<pre><code>\u521d\u59cb\u5316:\n  \u251c\u2500\u2500 SYSCFG_DL_init()       \u2014 \u7cfb\u7edf\u65f6\u949f\u4e0e\u5916\u8bbe\n  \u251c\u2500\u2500 SysTick_Init()          \u2014 SysTick \u5b9a\u65f6\u5668\n  \u251c\u2500\u2500 OLED_Init()             \u2014 OLED \u5c4f\u5e55\n  \u251c\u2500\u2500 WIT_Init()              \u2014 \u59ff\u6001\u4f20\u611f\u5668\n  \u251c\u2500\u2500 Motor_Init()            \u2014 \u7535\u673a PWM\n  \u251c\u2500\u2500 Encoder_Init()          \u2014 \u7f16\u7801\u5668\n  \u251c\u2500\u2500 Interrupt_Init()        \u2014 \u4e2d\u65ad\u914d\u7f6e\n  \u2514\u2500\u2500 PID_Init() \u00d73           \u2014 \u8f6c\u5411 PID + \u5de6\u53f3\u901f\u5ea6 PID\n\n\u4e3b\u5faa\u73af (20ms \u5468\u671f):\n  \u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n  \u2502  Grayscale_Sensor_Read_All()    \u2502 \u2190 \u8bfb\u53d6 8 \u8def\u7070\u5ea6\u503c\n  \u2502  Grayscale_CalcError()          \u2502 \u2190 \u8ba1\u7b97\u8d5b\u9053\u504f\u5dee\n  \u2502  \u250c\u2500 \u4e22\u7ebf\u68c0\u6d4b?                   \u2502\n  \u2502  \u2502  \u251c\u2500 \u5168\u767d \u2192 STOP              \u2502\n  \u2502  \u2502  \u251c\u2500 \u90e8\u5206\u4e22\u7ebf \u2192 \u4fdd\u6301\u4e0a\u6b21\u504f\u5dee   \u2502\n  \u2502  \u2502  \u2514\u2500 \u8fde\u7eed &gt;10\u6b21 \u2192 \u505c\u8f66        \u2502\n  \u2502  PID_Calculate(&amp;pid_turn)       \u2502 \u2190 \u8f6c\u5411 PID\n  \u2502  \u8ba1\u7b97\u76ee\u6807\u901f\u5ea6 L/R                \u2502\n  \u2502  PID_Calculate(&amp;pid_speed_L)    \u2502 \u2190 \u5de6\u901f\u5ea6 PID\n  \u2502  PID_Calculate(&amp;pid_speed_R)    \u2502 \u2190 \u53f3\u901f\u5ea6 PID\n  \u2502  CLAMP \u9650\u5e45                      \u2502\n  \u2502  Motor_SetSpeed()               \u2502 \u2190 \u8f93\u51fa PWM\n  \u2502  OLED \u5237\u65b0\u663e\u793a                   \u2502\n  \u2502  UART \u65e5\u5fd7\u8f93\u51fa                   \u2502\n  \u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n</code></pre>"},{"location":"architecture.html#_4","title":"\u4e2d\u65ad\u7cfb\u7edf","text":"\u4e2d\u65ad \u89e6\u53d1\u6e90 \u529f\u80fd TIMER_Encoder_Read \u5b9a\u65f6\u5668 \u5b9a\u671f\u8bfb\u53d6\u7f16\u7801\u5668\u503c TIMER_Control \u5b9a\u65f6\u5668 \u63a7\u5236\u5468\u671f\u7ba1\u7406 GPIO \u6309\u952e \u5916\u90e8\u4e2d\u65ad \u6a21\u5f0f\u5207\u6362 / \u6025\u505c"},{"location":"debug.html","title":"\u8c03\u8bd5\u4e0e\u65e5\u5fd7","text":""},{"location":"debug.html#uart","title":"UART \u8c03\u8bd5\u8f93\u51fa","text":"<p>\u7cfb\u7edf\u901a\u8fc7 UART \u4ee5 50Hz \u9891\u7387\u8f93\u51fa\u8fd0\u884c\u6570\u636e\u3002</p>"},{"location":"debug.html#_2","title":"\u8f93\u51fa\u683c\u5f0f","text":"<pre><code>dev:+23 L: 45 R: 38 cnt:5 SL: 45 SR: 42\ndev:+25 L: 47 R: 36 cnt:4 SL: 46 SR: 41\ndev:+20 L: 44 R: 39 cnt:5 SL: 44 SR: 43\n</code></pre> \u5b57\u6bb5 \u542b\u4e49 \u8303\u56f4 dev \u8d5b\u9053\u504f\u5dee \u00b11000 L \u5de6\u7535\u673a PWM 0-100 R \u53f3\u7535\u673a PWM 0-100 cnt \u68c0\u6d4b\u5230\u7684\u4f20\u611f\u5668\u6570 0-8 SL \u5de6\u7f16\u7801\u5668\u901f\u5ea6 0-100 SR \u53f3\u7f16\u7801\u5668\u901f\u5ea6 0-100"},{"location":"debug.html#_3","title":"\u8702\u9e23\u5668","text":"<pre><code>// \u5f00\u673a\u8702\u9e23\u63d0\u793a (500Hz, 100ms)\nDL_GPIO_setPins(GPIO_BEEP_PORT, GPIO_BEEP_PIN_BEEP_PIN);\ndelay_cycles(3200000);\nDL_GPIO_clearPins(GPIO_BEEP_PORT, GPIO_BEEP_PIN_BEEP_PIN);\n</code></pre>"},{"location":"debug.html#_4","title":"\u65e5\u5fd7\u5206\u6790\u6280\u5de7","text":"<pre><code># Python \u6570\u636e\u53ef\u89c6\u5316\u793a\u4f8b\nimport serial, matplotlib.pyplot as plt\n\nser = serial.Serial('COM3', 115200)\ndev, l, r = [], [], []\n\nwhile len(dev) &lt; 500:\n    line = ser.readline().decode().strip()\n    parts = line.split()\n    dev.append(int(parts[0].split(':')[1]))\n    l.append(int(parts[1].split(':')[1]))\n    r.append(int(parts[2].split(':')[1]))\n\nplt.plot(dev, label='Deviation')\nplt.plot(l, label='Motor L')\nplt.plot(r, label='Motor R')\nplt.legend(); plt.show()\n</code></pre>"},{"location":"display.html","title":"OLED \u663e\u793a","text":""},{"location":"display.html#_1","title":"\u663e\u793a\u5e03\u5c40","text":"<p>\u91c7\u7528 0.96\" 128\u00d764 OLED \u5c4f\u5e55\uff0c\u8f6f\u4ef6 I2C \u9a71\u52a8\u3002</p> <pre><code>\u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n\u2502 Dev:  +23    Car.101 PID \u2502  \u2190 \u884c0: \u504f\u5dee\u503c + \u9879\u76ee\u540d\n\u2502 L: 45  R: 38             \u2502  \u2190 \u884c2: \u5de6\u53f3\u7535\u673a\u8f93\u51fa\n\u2502 P:  18.4  I:  2.1  D: 6.9\u2502  \u2190 \u884c4: PID \u5206\u91cf\n\u2502 SPD: 45                  \u2502  \u2190 \u884c6: \u5de6\u7f16\u7801\u5668\u901f\u5ea6\n\u2502 11000111                 \u2502  \u2190 \u884c7: \u7070\u5ea6\u4f20\u611f\u5668\u72b6\u6001\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n</code></pre>"},{"location":"display.html#_2","title":"\u591a\u7248\u9a71\u52a8","text":"<p>\u9879\u76ee\u652f\u6301 4 \u79cd OLED \u9a71\u52a8\u65b9\u5f0f\uff1a</p> \u9a71\u52a8 \u63a5\u53e3 \u9002\u7528\u573a\u666f OLED_Software_I2C GPIO \u6a21\u62df I2C \u4efb\u610f\u5f15\u811a\uff0c\u901a\u7528\u6027\u6700\u5f3a OLED_Hardware_I2C \u786c\u4ef6 I2C \u9ad8\u901f\u5237\u65b0 OLED_Software_SPI GPIO \u6a21\u62df SPI \u9ad8\u901f\u4f20\u8f93 OLED_Hardware_SPI \u786c\u4ef6 SPI \u6700\u9ad8\u6027\u80fd"},{"location":"pid-control.html","title":"PID \u63a7\u5236","text":""},{"location":"pid-control.html#pid_1","title":"\u4e09\u8def PID \u63a7\u5236\u5668","text":"<p>\u7cfb\u7edf\u91c7\u7528 \u4e32\u7ea7 PID \u7ed3\u6784\uff0c\u4e00\u4e2a\u8f6c\u5411 PID \u8f93\u51fa\u4f5c\u4e3a\u4e24\u4e2a\u901f\u5ea6 PID \u7684\u76ee\u6807\u8f93\u5165\uff1a</p> <pre><code>                     \u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n  \u504f\u5dee \u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u25ba\u2502  \u8f6c\u5411 PID   \u2502\u2500\u2500\u2500\u25ba \u76ee\u6807\u901f\u5ea6\u5dee\n                     \u2502 Kp=0.8      \u2502      +\n                     \u2502 Ki=0.005    \u2502      \u2502\n                     \u2502 Kd=0.3      \u2502      \u25bc\n                     \u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518   \u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n                     \u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510   \u2502 \u5de6\u901f\u5ea6 PID   \u2502\n  \u76ee\u6807\u901f\u5ea6 L \u25c4\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2524  \u76ee\u6807\u901f\u5ea6   \u2502\u25c4\u2500\u2500\u2502 Kp=0.5       \u2502\u25c4\u2500\u2500 \u7f16\u7801\u5668\u53cd\u9988 L\n                     \u2502  \u5206\u914d       \u2502   \u2502 Ki=0.01      \u2502\n                     \u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518   \u2502 Kd=0.1       \u2502\n                                       \u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n                     \u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n  \u76ee\u6807\u901f\u5ea6 R \u25c4\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2524  \u76ee\u6807\u901f\u5ea6   \u2502   \u250c\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2510\n                     \u2502  \u5206\u914d       \u2502\u2500\u2500\u25ba\u2502 \u53f3\u901f\u5ea6 PID   \u2502\n                     \u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518   \u2502 Kp=0.5       \u2502\u25c4\u2500\u2500 \u7f16\u7801\u5668\u53cd\u9988 R\n                                       \u2502 Ki=0.01      \u2502\n                                       \u2502 Kd=0.1       \u2502\n                                       \u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\n</code></pre>"},{"location":"pid-control.html#pid_2","title":"PID \u53c2\u6570","text":"\u63a7\u5236\u5668 Kp Ki Kd \u8f93\u51fa\u9650\u5e45 \u79ef\u5206\u9650\u5e45 \u8f6c\u5411 PID 0.8 0.005 0.3 \u00b130 \u00b160 \u5de6\u901f\u5ea6 PID 0.5 0.01 0.1 \u00b120 \u00b150 \u53f3\u901f\u5ea6 PID 0.5 0.01 0.1 \u00b120 \u00b150"},{"location":"pid-control.html#_1","title":"\u79ef\u5206\u5206\u79bb","text":"<pre><code>if (fabs(error) &lt;= integral_limit) {\n    integral += error * Ki;\n    integral = CLAMP(integral, -integral_limit, integral_limit);\n} else {\n    integral = 0;  // \u8bef\u5dee\u8fc7\u5927\u65f6\u6e05\u9664\u79ef\u5206\n}\n</code></pre>"},{"location":"pid-control.html#_2","title":"\u901f\u5ea6\u5408\u6210","text":"<pre><code>// \u57fa\u7840\u901f\u5ea6\nconst int16_t base_speed = 40;\n\n// \u8f6c\u5411\u91cf\u53e0\u52a0\ntarget_speed_L = base_speed + turn_output;\ntarget_speed_R = base_speed - turn_output;\n\n// \u9650\u5e45\u5230 [0, 100]\ntarget_speed_L = CLAMP(target_speed_L, 0, 100);\ntarget_speed_R = CLAMP(target_speed_R, 0, 100);\n</code></pre>"},{"location":"pid-control.html#_3","title":"\u63a7\u5236\u5468\u671f","text":"<p>\u4e3b\u5faa\u73af\u8fd0\u884c\u5728 20ms \u5468\u671f\uff0c\u5373\u63a7\u5236\u9891\u7387\u4e3a 50Hz\u3002</p>"},{"location":"sensors.html","title":"\u4f20\u611f\u5668\u9a71\u52a8","text":""},{"location":"sensors.html#grayscale","title":"\u7070\u5ea6\u4f20\u611f\u5668 (Grayscale)","text":"<p>8 \u8def\u6570\u5b57\u7070\u5ea6\u4f20\u611f\u5668\uff0c\u7528\u4e8e\u68c0\u6d4b\u8d5b\u9053\u9ed1\u7ebf\u3002</p>"},{"location":"sensors.html#_2","title":"\u6570\u636e\u8bfb\u53d6","text":"<pre><code>uint8_t sensor_values[GRAYSCALE_CHANNELS];  // 8 \u8def\u6570\u636e\nGrayscale_Sensor_Read_All(sensor_values);\n</code></pre>"},{"location":"sensors.html#_3","title":"\u504f\u5dee\u8ba1\u7b97","text":"<pre><code>float deviation = Grayscale_CalcError(sensor_values, &amp;sensor_count, &amp;pattern);\n</code></pre> <ul> <li>\u8fd4\u56de: \u6d6e\u70b9\u504f\u5dee\u503c\uff0c\u8303\u56f4\u7ea6 <code>[-1000, 1000]</code></li> <li>\u5168\u767d: \u8fd4\u56de <code>10000</code>\uff0c\u89e6\u53d1 STOP</li> <li>\u6a21\u5f0f: \u68c0\u6d4b\u4e22\u7ebf\u3001\u5f2f\u9053\u3001\u5341\u5b57\u7b49\u7279\u5f81</li> </ul>"},{"location":"sensors.html#oled","title":"OLED \u663e\u793a","text":"<p>\u7070\u5ea6\u503c\u5b9e\u65f6\u663e\u793a\u5728 OLED \u6700\u540e\u4e00\u884c\uff0c\u683c\u5f0f\u4e3a 8 \u4f4d\u4e8c\u8fdb\u5236\u5b57\u7b26\u4e32\uff1a <pre><code>11000111  \u2190 8 \u8def\u4f20\u611f\u5668\u503c ('1'=\u767d, '0'=\u9ed1)\n</code></pre></p>"},{"location":"sensors.html#imu","title":"IMU \u59ff\u6001\u4f20\u611f\u5668","text":""},{"location":"sensors.html#bno08x-uart-rvc","title":"BNO08X (UART RVC \u6a21\u5f0f)","text":"<ul> <li>\u4e32\u53e3\u901a\u4fe1\uff0c\u8f93\u51fa\u6b27\u62c9\u89d2/\u56db\u5143\u6570</li> <li>\u5185\u7f6e\u59ff\u6001\u878d\u5408\u7b97\u6cd5</li> </ul>"},{"location":"sensors.html#imu660rb","title":"IMU660RB","text":"<ul> <li>6 \u8f74 IMU + Fusion \u5e93</li> <li>\u652f\u6301 AHRS \u59ff\u6001\u89e3\u7b97</li> </ul>"},{"location":"sensors.html#mpu6050-dmp","title":"MPU6050 + DMP","text":"<ul> <li>6 \u8f74 + \u786c\u4ef6 DMP \u5f15\u64ce</li> <li>\u76f4\u63a5\u8f93\u51fa\u56db\u5143\u6570/\u6b27\u62c9\u89d2</li> </ul>"},{"location":"sensors.html#_4","title":"\u6d4b\u8ddd\u6a21\u5757","text":"\u6a21\u5757 \u63a5\u53e3 \u91cf\u7a0b \u7cbe\u5ea6 VL53L0X I2C 0~2m \u00b13% HC-SR04 (Capture) \u8f93\u5165\u6355\u83b7 2cm~4m \u00b11cm HC-SR04 (GPIO) GPIO \u6a21\u62df 2cm~4m \u00b11cm"}]}